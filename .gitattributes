# Unity text normalization
* text=auto
*.cs text diff=csharp
*.shader text
*.cginc text
*.hlsl text
*.json text
*.asmdef text
*.asmref text
*.uxml text
*.uss text
*.unity text eol=lf
*.prefab text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.overrideController text eol=lf
*.physicsMaterial2D text eol=lf
*.physicMaterial text eol=lf

# Common Unity binary assets via Git LFS
*.psd filter=lfs diff=lfs merge=lfs -text
